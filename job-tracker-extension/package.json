{
  "name": "job-tracker-extension",
  "version": "1.1.0",
  "description": "Chrome extension to capture job postings to Notion",
  "type": "module",
  "scripts": {
    "build": "cd .. && node scripts/build.js",
    "test": "node --test tests/parsers.test.js",
    "test:watch": "node --test --watch tests/parsers.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2022": true,
      "webextensions": true
    },
    "extends": [
      "eslint:recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "off"
    }
  },
  "prettier": {
    "singleQuote": true,
    "semi": true,
    "printWidth": 100,
    "trailingComma": "es5"
  }
}
