{
  "manifest_version": 3,
  "name": "Job Tracker",
  "version": "1.0.0",
  "description": "Capture job postings to Notion with one click",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://api.notion.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon_idle_16.png",
      "48": "icons/icon_idle_48.png",
      "128": "icons/icon_idle_128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon_idle_16.png",
    "48": "icons/icon_idle_48.png",
    "128": "icons/icon_idle_128.png"
  }
}
